<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/maui/global"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BarcodeGenerator.PageSettings"
             SafeAreaEdges="All">

    <Shell.TitleView>
        <Label
            Style="{StaticResource labelStyleTitleView}"
            Text="{Translate Settings_Text}">
        </Label>
    </Shell.TitleView>

    <Grid
        x:Name="grdMainFixed"
        RowDefinitions="Auto, *, Auto"
        HorizontalOptions="Center"
        Margin="5"
        SafeAreaEdges="Container,SoftInput">

        <ScrollView
            Grid.Row="1"
            Grid.Column="0"
            Orientation="Vertical">

            <Grid
                x:Name="grdSettings"
                Style="{StaticResource gridStyleSettings}"
                RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto, 4, Auto, Auto, Auto, Auto, 4, Auto, Auto, Auto, Auto, 4, Auto, Auto, Auto, Auto, 4, Auto">

                <Border
                    Style="{StaticResource borderStyleDefault}"
                    Grid.Row="0"
                    Grid.Column="0"
                    Grid.ColumnSpan="3">

                    <Label
                        Style="{StaticResource labelStyleExplanation}"
                        Text="{Translate SettingsSaved_Text}">
                    </Label>
                </Border>

                <Label
                    Style="{StaticResource labelStyleDefault}"
                    Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Text="{Translate Language_Text}">
                </Label>

                <Border
                    Style="{StaticResource borderStyleDefault}"
                    Grid.Row="1"
                    Grid.Column="2">

                    <Picker
                        x:Name="pckLanguage"
                        Style="{StaticResource pickerStyleSettings}"
                        Grid.Row="1"
                        Grid.Column="2"
                        SelectedIndexChanged="OnPickerLanguageChanged">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>Čeština</x:String>
                                <x:String>Dansk</x:String>
                                <x:String>Deutsch</x:String>
                                <x:String>English</x:String>
                                <x:String>Español</x:String>
                                <x:String>Français</x:String>
                                <x:String>Italiano</x:String>
                                <x:String>Magyar</x:String>
                                <x:String>Nederlands</x:String>
                                <x:String>Norsk</x:String>
                                <x:String>Polski</x:String>
                                <x:String>Português</x:String>
                                <x:String>Română</x:String>
                                <x:String>Suomi</x:String>
                                <x:String>Svenska</x:String>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>
                </Border>

                <Label
                    Style="{StaticResource labelStyleDefault}"
                    Grid.Row="2"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Text="{Translate LanguageSpeech_Text}">
                </Label>

                <Border
                    Style="{StaticResource borderStyleDefault}"
                    Grid.Row="2"
                    Grid.Column="2">

                    <Picker
                        x:Name="pckLanguageSpeech"
                        Style="{StaticResource pickerStyleSettings}"
                        Grid.Row="2"
                        Grid.Column="2"
                        SelectedIndexChanged="OnPickerLanguageSpeechChanged">
                    </Picker>
                </Border>

                <Label
                    Style="{StaticResource labelStyleDefault}"
                    Grid.Row="3"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Text="{Translate Theme_Text}">
                </Label>

                <Border
                    Style="{StaticResource borderStyleDefault}"
                    Grid.Row="3"
                    Grid.Column="2">

                    <Picker
                        x:Name="pckTheme"
                        Style="{StaticResource pickerStyleSettings}"
                        Grid.Row="3"
                        Grid.Column="2"
                        SelectedIndexChanged="OnPickerThemeChanged">
                    </Picker>
                </Border>

                <Label
                    Style="{StaticResource labelStyleDefault}"
                    Grid.Row="4"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Text="{Translate DefaultFormatGenerator_Text}">
                </Label>

                <Border
                    Style="{StaticResource borderStyleDefault}"
                    Grid.Row="4"
                    Grid.Column="2">

                    <Picker
                        x:Name="pckFormatCodeGenerator"
                        Style="{StaticResource pickerStyleSettings}"
                        Grid.Row="4"
                        Grid.Column="2"
                        SelectedIndexChanged="OnPickerFormatCodeGeneratorChanged">
                    </Picker>
                </Border>

                <Label
                    Style="{StaticResource labelStyleDefault}"
                    Grid.Row="5"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Text="{Translate DefaultFormatScanner_Text}">
                </Label>

                <Border
                    Style="{StaticResource borderStyleDefault}"
                    Grid.Row="5"
                    Grid.Column="2">

                    <Picker
                        x:Name="pckFormatCodeScanner"
                        Style="{StaticResource pickerStyleSettings}"
                        Grid.Row="5"
                        Grid.Column="2"
                        SelectedIndexChanged="OnPickerFormatCodeScannerChanged">
                    </Picker>
                </Border>

                <Label
                    x:Name="lblHexColorFg"
                    Style="{StaticResource labelStyleDefault}"
                    Grid.Row="7"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    VerticalTextAlignment="Start"
                    Text="{Translate ForegroundColor_Text}">
                </Label>

                <Border
                    Grid.Row="8"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    HeightRequest="40"
                    BackgroundColor="Transparent"
                    Stroke="{AppThemeBinding Light={StaticResource MidGray}, Dark={StaticResource MidGray}}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 5,5,5,5">

                    <BoxView
                        x:Name="bxvColorFg"
                        Grid.Row="8"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Color="Black">
                    </BoxView>
                </Border>

                <Button
                    Style="{StaticResource buttonStyleDefault}"
                    Grid.Row="8"
                    Grid.Column="2"
                    Text="Color picker foreground"
                    Clicked="OnButtonColorForgroundClicked">
                </Button>

                <Label
                    x:Name="lblHexColorBg"
                    Style="{StaticResource labelStyleDefault}"
                    Grid.Row="13"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    VerticalTextAlignment="Start"
                    Text="{Translate BackgroundColor_Text}">
                </Label>

                <Border
                    Grid.Row="15"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    HeightRequest="40"
                    BackgroundColor="Transparent"
                    Stroke="{AppThemeBinding Light={StaticResource MidGray}, Dark={StaticResource MidGray}}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 5,5,5,5">
                    
                    <BoxView
                        x:Name="bxvColorBg"
                        Grid.Row="15"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Color="White">
                    </BoxView>
                </Border>

                <Button
                    Style="{StaticResource buttonStyleDefault}"
                    Grid.Row="15"
                    Grid.Column="2"
                    Text="Color picker background"
                    Clicked="OnButtonColorBackgroundClicked">
                </Button>

                <Label
                    Style="{StaticResource labelStyleDefault}"
                    Grid.Row="17"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    VerticalTextAlignment="Start"
                    Text="{Translate QRCodeSizeVariable_Text}">
                </Label>

                <Switch
                    x:Name="swtQRCodeSizeVariable"
                    Grid.Row="17"
                    Grid.Column="2"
                    HorizontalOptions="Start"
                    Toggled="SwtQRCodeSizeVariable_Toggled"  >
                </Switch>

                <Label
                    Style="{StaticResource labelStyleDefault}"
                    Grid.Row="18"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    VerticalTextAlignment="Start"
                    Text="{Translate QRCodeSizePixels_Text}">
                </Label>

                <Border
                    Style="{StaticResource borderStyleDefault}"
                    Grid.Row="18"
                    Grid.Column="2">

                    <Entry
                        x:Name="entQRCodeSizePixels"
                        Grid.Row="18"
                        Grid.Column="2"
                        ClearButtonVisibility="WhileEditing"
                        MaxLength="5"
                        Placeholder="500 - 10000"
                        Keyboard="Numeric"
                        ReturnType="Next"
                        TextChanged="EntQRCodeSizePixels_TextChanged"
                        Unfocused="EntQRCodeSizePixels_Unfocused" >
                    </Entry>
                </Border>

                <Label
                    x:Name="lblQRCodeImageSize"
                    Style="{StaticResource labelStyleDefault}"
                    Grid.Row="19"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    VerticalTextAlignment="Start"
                    Text="{Translate QRCodeImageSize_Text}">
                </Label>
                
                <Border
                    Style="{StaticResource borderStyleGroup}"
                    Grid.Row="19"
                    Grid.Column="2"
                    Grid.RowSpan="1">
                
                    <Slider
                        x:Name="sldQRCodeImageSize"
                        Style="{StaticResource sliderStyleColor}"
                        Grid.Row="19"
                        Grid.Column="2"
                        ThumbColor="Orange"
                        MinimumTrackColor="Orange"
                        Minimum="10"
                        Maximum="35"
                        ValueChanged="OnSliderQRCodeImageSizeValueChanged">
                    </Slider>
                </Border>

                <Label
                    x:Name="lblArtQRCodeOpacityBg"
                    Style="{StaticResource labelStyleDefault}"
                    Grid.Row="20"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    VerticalTextAlignment="Start"
                    Text="{Translate BackgroundOpacityArt_Text}">
                </Label>

                <Border
                    Style="{StaticResource borderStyleGroup}"
                    Grid.Row="20"
                    Grid.Column="2"
                    Grid.RowSpan="1">

                    <Slider
                        x:Name="sldArtQRCodeOpacityBg"
                        Style="{StaticResource sliderStyleColor}"
                        Grid.Row="20"
                        Grid.Column="2"
                        ThumbColor="Violet"
                        MinimumTrackColor="Violet"
                        ValueChanged="SldArtQRCodeOpacityBg_ValueChanged">
                    </Slider>
                </Border>

                <Label
                    Style="{StaticResource labelStyleDefault}"
                    Grid.Row="22"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    VerticalTextAlignment="Start"
                    Text="{Translate BarcodeWithCaption_Text}">
                </Label>

                <Switch
                    x:Name="swtBarcodeWithCaption"
                    Grid.Row="22"
                    Grid.Column="2"
                    HorizontalOptions="Start"
                    Toggled="SwtBarcodeWithCaption_Toggled">
                </Switch>

            </Grid>
        </ScrollView>

        <Button
            Style="{StaticResource buttonStyleDefault}"
            Grid.Row="2"
            Text="{Translate SettingsSave_Text}"
            SemanticProperties.Description="{Translate ToolTipSettingsSave_Text}"
            ToolTipProperties.Text="{Translate ToolTipSettingsSave_Text}"
            Clicked="OnSettingsSaveClicked">
        </Button>

        <Button
            Style="{StaticResource buttonStyleDefault}"
            Grid.Row="2"
            HorizontalOptions="End"
            Text="{Translate SettingsReset_Text}"
            SemanticProperties.Description="{Translate ToolTipSettingsReset_Text}"
            ToolTipProperties.Text="{Translate ToolTipSettingsReset_Text}"
            Clicked="OnSettingsResetClicked">
        </Button>

    </Grid>
</ContentPage>
