<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/maui/global"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BarcodeGenerator.PageSettings"
             SafeAreaEdges="All">

    <Shell.TitleView>
        <Label
            Style="{StaticResource labelStyleTitleView}"
            Text="{Translate Settings_Text}">
        </Label>
    </Shell.TitleView>

    <Grid
        x:Name="grdMainFixed"
        RowDefinitions="Auto, *, Auto"
        HorizontalOptions="Center"
        RowSpacing="1"
        Margin="4"
        SafeAreaEdges="Container,SoftInput">

        <ScrollView
            Grid.Row="1"
            Grid.Column="0"
            Orientation="Vertical">

            <Grid
                x:Name="grdSettings"
                Style="{StaticResource gridStyleSettings}"
                RowSpacing="4"
                RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto">

                <Border
                    Style="{StaticResource borderStyleDefault}"
                    Grid.Row="0"
                    Grid.Column="0"
                    Grid.ColumnSpan="2">

                    <Label
                        Style="{StaticResource labelStyleExplanation}"
                        Text="{Translate SettingsSaved_Text}">
                    </Label>
                </Border>

                <Label
                    Style="{StaticResource labelStyleDefault}"
                    Grid.Row="1"
                    Grid.Column="0"
                    Text="{Translate Language_Text}">
                </Label>

                <Border
                    Style="{StaticResource borderStyleDefault}"
                    Grid.Row="1"
                    Grid.Column="1">

                    <Picker
                        x:Name="pckLanguage"
                        Style="{StaticResource pickerStyleSettings}"
                        SelectedIndexChanged="OnPickerLanguageChanged">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>Čeština</x:String>
                                <x:String>Dansk</x:String>
                                <x:String>Deutsch</x:String>
                                <x:String>English</x:String>
                                <x:String>Español</x:String>
                                <x:String>Français</x:String>
                                <x:String>Italiano</x:String>
                                <x:String>Magyar</x:String>
                                <x:String>Nederlands</x:String>
                                <x:String>Norsk</x:String>
                                <x:String>Polski</x:String>
                                <x:String>Português</x:String>
                                <x:String>Română</x:String>
                                <x:String>Suomi</x:String>
                                <x:String>Svenska</x:String>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>
                </Border>

                <Label
                    Style="{StaticResource labelStyleDefault}"
                    Grid.Row="2"
                    Grid.Column="0"
                    Text="{Translate LanguageSpeech_Text}">
                </Label>

                <Border
                    Style="{StaticResource borderStyleDefault}"
                    Grid.Row="2"
                    Grid.Column="1">

                    <Picker
                        x:Name="pckLanguageSpeech"
                        Style="{StaticResource pickerStyleSettings}"
                        SelectedIndexChanged="OnPickerLanguageSpeechChanged">
                    </Picker>
                </Border>

                <Label
                    Style="{StaticResource labelStyleDefault}"
                    Grid.Row="3"
                    Grid.Column="0"
                    Text="{Translate Theme_Text}">
                </Label>

                <Border
                    Style="{StaticResource borderStyleDefault}"
                    Grid.Row="3"
                    Grid.Column="1">

                    <Picker
                        x:Name="pckTheme"
                        Style="{StaticResource pickerStyleSettings}"
                        SelectedIndexChanged="OnPickerThemeChanged">
                    </Picker>
                </Border>

                <Label
                    Style="{StaticResource labelStyleDefault}"
                    Grid.Row="4"
                    Grid.Column="0"
                    Text="{Translate DefaultFormatGenerator_Text}">
                </Label>

                <Border
                    Style="{StaticResource borderStyleDefault}"
                    Grid.Row="4"
                    Grid.Column="1">

                    <Picker
                        x:Name="pckFormatCodeGenerator"
                        Style="{StaticResource pickerStyleSettings}"
                        SelectedIndexChanged="OnPickerFormatCodeGeneratorChanged">
                    </Picker>
                </Border>

                <Label
                    Style="{StaticResource labelStyleDefault}"
                    Grid.Row="5"
                    Grid.Column="0"
                    Text="{Translate DefaultFormatScanner_Text}">
                </Label>

                <Border
                    Style="{StaticResource borderStyleDefault}"
                    Grid.Row="5"
                    Grid.Column="1">

                    <Picker
                        x:Name="pckFormatCodeScanner"
                        Style="{StaticResource pickerStyleSettings}"
                        SelectedIndexChanged="OnPickerFormatCodeScannerChanged">
                    </Picker>
                </Border>

                <Label
                    x:Name="lblHexColorFg"
                    Style="{StaticResource labelStyleDefault}"
                    Grid.Row="6"
                    Grid.Column="0"
                    Text="{Translate ForegroundColor_Text}">
                </Label>

                <Grid
                    Grid.Row="6"
                    Grid.Column="2"
                    ColumnDefinitions="48, 100*">

                    <ImageButton
                        Style="{StaticResource imageButtonStyleColorPicker}"
                        Grid.Column="0"
                        Source="ic_action_settings.png"
                        SemanticProperties.Description="{Translate ColorPicker_Text}"
                        ToolTipProperties.Text="{Translate ColorPicker_Text}"
                        Clicked="OnButtonColorForgroundClicked">
                    </ImageButton>

                    <Border
                        Grid.Column="1"
                        HeightRequest="40"
                        BackgroundColor="Transparent"
                        Stroke="{AppThemeBinding Light={StaticResource MidGray}, Dark={StaticResource MidGray}}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 5,5,5,5">

                        <BoxView
                            x:Name="bxvColorFg"
                            Color="Black">
                        </BoxView>
                    </Border>
                </Grid>

                <Label
                    x:Name="lblHexColorBg"
                    Style="{StaticResource labelStyleDefault}"
                    Grid.Row="7"
                    Grid.Column="0"
                    Text="{Translate BackgroundColor_Text}">
                </Label>

                <Grid
                    Grid.Row="7"
                    Grid.Column="2"
                    ColumnDefinitions="48, 100*">

                    <ImageButton
                        Style="{StaticResource imageButtonStyleColorPicker}"
                        Grid.Column="0"
                        Source="ic_action_settings.png"
                        SemanticProperties.Description="{Translate ColorPicker_Text}"
                        ToolTipProperties.Text="{Translate ColorPicker_Text}"
                        Clicked="OnButtonColorBackgroundClicked">
                    </ImageButton>

                    <Border
                        Grid.Column="1"
                        HeightRequest="40"
                        BackgroundColor="Transparent"
                        Stroke="{AppThemeBinding Light={StaticResource MidGray}, Dark={StaticResource MidGray}}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 5,5,5,5">

                        <BoxView
                            x:Name="bxvColorBg"
                            Color="White">
                        </BoxView>
                    </Border>
                </Grid>

                <Label
                    x:Name="lblHexColorBgArtQRCode"
                    Style="{StaticResource labelStyleDefault}"
                    Grid.Row="8"
                    Grid.Column="0"
                    Text="{Translate BackgroundColorArtQRCode_Text}">
                </Label>

                <Grid
                    Grid.Row="8"
                    Grid.Column="2"
                    ColumnDefinitions="48, 100*">

                    <ImageButton
                        Style="{StaticResource imageButtonStyleColorPicker}"
                        Grid.Column="0"
                        Source="ic_action_settings.png"
                        SemanticProperties.Description="{Translate ColorPicker_Text}"
                        ToolTipProperties.Text="{Translate ColorPicker_Text}"
                        Clicked="OnButtonColorBackgroundArtQRCodeClicked">
                    </ImageButton>

                    <Border
                        Grid.Column="1"
                        HeightRequest="40"
                        BackgroundColor="Transparent"
                        Stroke="{AppThemeBinding Light={StaticResource MidGray}, Dark={StaticResource MidGray}}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 5,5,5,5">

                        <BoxView
                            x:Name="bxvColorBgArtQRCode"
                            Color="White">
                        </BoxView>
                    </Border>
                </Grid>

                <Label
                    Style="{StaticResource labelStyleDefault}"
                    Grid.Row="9"
                    Grid.Column="0"
                    Text="{Translate QRCodeModuleShape_Text}">
                </Label>

                <Grid
                    Grid.Row="9"
                    Grid.Column="2"
                    RowDefinitions="Auto"
                    ColumnDefinitions="30, 32, 30, 32, 30, 30" >
                    
                    <RadioButton
                        x:Name="rbtQRCodeModuleShapeSquare"
                        GroupName="ModuleShape"
                        Grid.Column="0"
                        HorizontalOptions="Start"
                        Margin="{OnPlatform Default='0,0,0,0', WinUI='5,5,0,0'}"
                        ToolTipProperties.Text="{Translate QRCodeModuleShapeSquare_Text}"
                        SemanticProperties.Description="{Translate QRCodeModuleShapeSquare_Text}"
                        CheckedChanged="RbtQRCodeModuleShape_CheckedChanged">
                    </RadioButton>

                    <BoxView
                        Grid.Column="1"
                        HeightRequest="27"
                        WidthRequest="27"
                        CornerRadius="0"
                        HorizontalOptions="Start"
                        Color="{AppThemeBinding Light={StaticResource MidGray}, Dark={StaticResource LightGray}}"
                        ToolTipProperties.Text="{Translate QRCodeModuleShapeSquare_Text}"
                        SemanticProperties.Description="{Translate QRCodeModuleShapeSquare_Text}">
                    </BoxView>

                    <RadioButton
                        x:Name="rbtQRCodeModuleShapeRounded"
                        GroupName="ModuleShape"
                        Grid.Column="2"
                        HorizontalOptions="Start"
                        Margin="{OnPlatform Default='0,0,0,0', WinUI='5,5,0,0'}"
                        ToolTipProperties.Text="{Translate QRCodeModuleShapeRounded_Text}"
                        SemanticProperties.Description="{Translate QRCodeModuleShapeRounded_Text}"
                        CheckedChanged="RbtQRCodeModuleShape_CheckedChanged">
                    </RadioButton>

                    <BoxView
                        Grid.Column="3"
                        HeightRequest="28"
                        WidthRequest="28"
                        CornerRadius="10"
                        HorizontalOptions="Start"
                        Color="{AppThemeBinding Light={StaticResource MidGray}, Dark={StaticResource LightGray}}"
                        ToolTipProperties.Text="{Translate QRCodeModuleShapeRounded_Text}"
                        SemanticProperties.Description="{Translate QRCodeModuleShapeRounded_Text}">
                    </BoxView>

                    <RadioButton
                        x:Name="rbtQRCodeModuleShapeCircle"
                        GroupName="ModuleShape"
                        Grid.Column="4"
                        HorizontalOptions="Start"
                        Margin="{OnPlatform Default='0,0,0,0', WinUI='5,5,0,0'}"
                        ToolTipProperties.Text="{Translate QRCodeModuleShapeCircle_Text}"
                        SemanticProperties.Description="{Translate QRCodeModuleShapeCircle_Text}"
                        CheckedChanged="RbtQRCodeModuleShape_CheckedChanged">
                    </RadioButton>

                    <BoxView
                        Grid.Column="5"
                        HeightRequest="29"
                        WidthRequest="29"
                        CornerRadius="25"
                        HorizontalOptions="Start"
                        Color="{AppThemeBinding Light={StaticResource MidGray}, Dark={StaticResource LightGray}}"
                        ToolTipProperties.Text="{Translate QRCodeModuleShapeCircle_Text}"
                        SemanticProperties.Description="{Translate QRCodeModuleShapeCircle_Text}">
                    </BoxView>
                </Grid>

                <Label
                    Style="{StaticResource labelStyleDefault}"
                    Grid.Row="10"
                    Grid.Column="0"
                    VerticalTextAlignment="Start"
                    Margin="{OnPlatform Default='0,0,0,0', iOS='0,6,0,0'}"
                    Text="{Translate QRCodeGradient_Text}">
                </Label>

                <Switch
                    x:Name="swtQRCodeGradient"
                    Grid.Row="10"
                    Grid.Column="2"
                    HorizontalOptions="Start"
                    Margin="{OnPlatform Default='0,0,0,0', iOS='0,6,0,0'}"
                    Toggled="SwtQRCodeGradient_Toggled">
                </Switch>

                <Label
                    Style="{StaticResource labelStyleDefault}"
                    Grid.Row="11"
                    Grid.Column="0"
                    Text="Gradient colors">
                </Label>

                <Grid
                    Grid.Row="11"
                    Grid.Column="2"
                    RowDefinitions="Auto"
                    ColumnDefinitions="Auto, Auto, Auto"
                    ColumnSpacing="12">

                    <Border
                        Grid.Column="0"
                        Stroke="{AppThemeBinding Light={StaticResource MidGray}, Dark={StaticResource MidGray}}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 5,5,5,5">

                        <BoxView
                            x:Name="bxvGradientColor1"
                            HeightRequest="50"
                            WidthRequest="50"
                            HorizontalOptions="Start"
                            ToolTipProperties.Text="{Translate QRCodeModuleShapeSquare_Text}"
                            SemanticProperties.Description="{Translate QRCodeModuleShapeSquare_Text}">
                        </BoxView>
                    </Border>

                    <ImageButton
                        Style="{StaticResource imageButtonStyleColorPicker}"
                        Grid.Column="0"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        BackgroundColor ="{AppThemeBinding Light={StaticResource LightGray}, Dark={StaticResource DarkGray}}"
                        Source="ic_action_settings.png"
                        SemanticProperties.Description="{Translate ColorPicker_Text}"
                        ToolTipProperties.Text="{Translate ColorPicker_Text}"
                        Clicked="OnButtonGradientColor1Clicked">
                    </ImageButton>

                    <Border
                        Grid.Column="1"
                        Stroke="{AppThemeBinding Light={StaticResource MidGray}, Dark={StaticResource MidGray}}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 5,5,5,5">

                        <BoxView
                            x:Name="bxvGradientColor2"
                            HeightRequest="50"
                            WidthRequest="50"
                            HorizontalOptions="Start"
                            ToolTipProperties.Text="{Translate QRCodeModuleShapeSquare_Text}"
                            SemanticProperties.Description="{Translate QRCodeModuleShapeSquare_Text}">
                        </BoxView>
                    </Border>

                    <ImageButton
                        Style="{StaticResource imageButtonStyleColorPicker}"
                        Grid.Column="1"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        BackgroundColor ="{AppThemeBinding Light={StaticResource LightGray}, Dark={StaticResource DarkGray}}"
                        Source="ic_action_settings.png"
                        SemanticProperties.Description="{Translate ColorPicker_Text}"
                        ToolTipProperties.Text="{Translate ColorPicker_Text}"
                        Clicked="OnButtonGradientColor2Clicked">
                    </ImageButton>

                    <Border
                        Grid.Column="2"
                        Stroke="{AppThemeBinding Light={StaticResource MidGray}, Dark={StaticResource MidGray}}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 5,5,5,5">

                        <BoxView
                            x:Name="bxvGradientColor3"
                            HeightRequest="50"
                            WidthRequest="50"
                            HorizontalOptions="Start"
                            ToolTipProperties.Text="{Translate QRCodeModuleShapeSquare_Text}"
                            SemanticProperties.Description="{Translate QRCodeModuleShapeSquare_Text}">
                        </BoxView>
                    </Border>

                    <ImageButton
                        Style="{StaticResource imageButtonStyleColorPicker}"
                        Grid.Column="2"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        BackgroundColor ="{AppThemeBinding Light={StaticResource LightGray}, Dark={StaticResource DarkGray}}"
                        Source="ic_action_settings.png"
                        SemanticProperties.Description="{Translate ColorPicker_Text}"
                        ToolTipProperties.Text="{Translate ColorPicker_Text}"
                        Clicked="OnButtonGradientColor3Clicked">
                    </ImageButton>                
                </Grid>

                <Label
                    Style="{StaticResource labelStyleDefault}"
                    Grid.Row="12"
                    Grid.Column="0"
                    VerticalOptions="Start"
                    Text="Gradient direction">
                </Label>

                <Grid
                    Grid.Row="12"
                    Grid.Column="2"
                    RowDefinitions="Auto, Auto"
                    ColumnDefinitions="Auto, Auto, Auto, Auto"
                    RowSpacing="8"
                    ColumnSpacing="8"
                    Padding="0,4,0,0">

                    <ImageButton
                        x:Name="btnQRCodeGradientDirection1"
                        Style="{StaticResource imageButtonStyleGradientDirectionPicker}"
                        Grid.Column="0"
                        Source="ic_action_arrow_top.png"
                        SemanticProperties.Description="{Translate ColorPicker_Text}"
                        ToolTipProperties.Text="{Translate ColorPicker_Text}"
                        Clicked="OnButtonQRCodeGradientDirectionClicked">
                    </ImageButton>

                    <ImageButton
                        x:Name="btnQRCodeGradientDirection2"
                        Style="{StaticResource imageButtonStyleGradientDirectionPicker}"
                        Grid.Column="1"
                        Source="ic_action_arrow_right_top.png"
                        SemanticProperties.Description="{Translate ColorPicker_Text}"
                        ToolTipProperties.Text="{Translate ColorPicker_Text}"
                        Clicked="OnButtonQRCodeGradientDirectionClicked">
                    </ImageButton>

                    <ImageButton
                        x:Name="btnQRCodeGradientDirection3"
                        Style="{StaticResource imageButtonStyleGradientDirectionPicker}"
                        Grid.Column="2"
                        Source="ic_action_arrow_right.png"
                        SemanticProperties.Description="{Translate ColorPicker_Text}"
                        ToolTipProperties.Text="{Translate ColorPicker_Text}"
                        Clicked="OnButtonQRCodeGradientDirectionClicked">
                    </ImageButton>

                    <ImageButton
                        x:Name="btnQRCodeGradientDirection4"
                        Style="{StaticResource imageButtonStyleGradientDirectionPicker}"
                        Grid.Column="3"
                        Source="ic_action_arrow_right_bottom.png"
                        SemanticProperties.Description="{Translate ColorPicker_Text}"
                        ToolTipProperties.Text="{Translate ColorPicker_Text}"
                        Clicked="OnButtonQRCodeGradientDirectionClicked">
                    </ImageButton>

                    <ImageButton
                        x:Name="btnQRCodeGradientDirection5"
                        Style="{StaticResource imageButtonStyleGradientDirectionPicker}"
                        Grid.Row="1"
                        Grid.Column="0"
                        Source="ic_action_arrow_bottom.png"
                        SemanticProperties.Description="{Translate ColorPicker_Text}"
                        ToolTipProperties.Text="{Translate ColorPicker_Text}"
                        Clicked="OnButtonQRCodeGradientDirectionClicked">
                    </ImageButton>

                    <ImageButton
                        x:Name="btnQRCodeGradientDirection6"
                        Style="{StaticResource imageButtonStyleGradientDirectionPicker}"
                        Grid.Row="1"
                        Grid.Column="1"
                        Source="ic_action_arrow_left_bottom.png"
                        SemanticProperties.Description="{Translate ColorPicker_Text}"
                        ToolTipProperties.Text="{Translate ColorPicker_Text}"
                        Clicked="OnButtonQRCodeGradientDirectionClicked">
                    </ImageButton>

                    <ImageButton
                        x:Name="btnQRCodeGradientDirection7"
                        Style="{StaticResource imageButtonStyleGradientDirectionPicker}"
                        Grid.Row="1"
                        Grid.Column="2"
                        Source="ic_action_arrow_left.png"
                        SemanticProperties.Description="{Translate ColorPicker_Text}"
                        ToolTipProperties.Text="{Translate ColorPicker_Text}"
                        Clicked="OnButtonQRCodeGradientDirectionClicked">
                    </ImageButton>

                    <ImageButton
                        x:Name="btnQRCodeGradientDirection8"
                        Style="{StaticResource imageButtonStyleGradientDirectionPicker}"
                        Grid.Row="1"
                        Grid.Column="3"
                        Source="ic_action_arrow_left_top.png"
                        SemanticProperties.Description="{Translate ColorPicker_Text}"
                        ToolTipProperties.Text="{Translate ColorPicker_Text}"
                        Clicked="OnButtonQRCodeGradientDirectionClicked">
                    </ImageButton>
                </Grid>

                <Label
                    Style="{StaticResource labelStyleDefault}"
                    Grid.Row="13"
                    Grid.Column="0"
                    VerticalTextAlignment="Start"
                    Margin="{OnPlatform Default='0,0,0,0', iOS='0,6,0,0'}"
                    Text="{Translate QRCodeSizeVariable_Text}">
                </Label>

                <Switch
                    x:Name="swtQRCodeSizeVariable"
                    Grid.Row="13"
                    Grid.Column="2"
                    HorizontalOptions="Start"
                    Margin="{OnPlatform Default='0,0,0,0', iOS='0,6,0,0'}"
                    Toggled="SwtQRCodeSizeVariable_Toggled"  >
                </Switch>

                <Label
                    Style="{StaticResource labelStyleDefault}"
                    Grid.Row="14"
                    Grid.Column="0"
                    VerticalTextAlignment="Start"
                    Text="{Translate QRCodeSizePixels_Text}">
                </Label>

                <Border
                    Style="{StaticResource borderStyleDefault}"
                    Grid.Row="14"
                    Grid.Column="1">

                    <Entry
                        x:Name="entQRCodeSizePixels"
                        ClearButtonVisibility="WhileEditing"
                        MaxLength="5"
                        Placeholder="500 - 10000"
                        Keyboard="Numeric"
                        ReturnType="Next"
                        TextChanged="EntQRCodeSizePixels_TextChanged"
                        Unfocused="EntQRCodeSizePixels_Unfocused" >
                    </Entry>
                </Border>

                <Label
                    x:Name="lblQRCodeImageSize"
                    Style="{StaticResource labelStyleDefault}"
                    Grid.Row="15"
                    Grid.Column="0"
                    VerticalTextAlignment="Start"
                    Text="{Translate QRCodeImageSize_Text}">
                </Label>
                
                <Border
                    Style="{StaticResource borderStyleGroup}"
                    Grid.Row="15"
                    Grid.Column="2"
                    Grid.RowSpan="1">
                
                    <Slider
                        x:Name="sldQRCodeImageSize"
                        Style="{StaticResource sliderStyleColor}"
                        Margin="10,7,10,0"
                        ThumbColor="Orange"
                        MinimumTrackColor="Orange"
                        Minimum="10"
                        Maximum="35"
                        ValueChanged="OnSliderQRCodeImageSizeValueChanged">
                    </Slider>
                </Border>

                <Label
                    Style="{StaticResource labelStyleDefault}"
                    Grid.Row="16"
                    Grid.Column="0"
                    VerticalTextAlignment="Start"
                    Margin="{OnPlatform Default='0,0,0,0', iOS='0,6,0,0'}"
                    Text="{Translate BarcodeWithCaption_Text}">
                </Label>

                <Switch
                    x:Name="swtBarcodeWithCaption"
                    Grid.Row="16"
                    Grid.Column="2"
                    HorizontalOptions="Start"
                    Margin="{OnPlatform Default='0,0,0,0', iOS='0,6,0,0'}"
                    Toggled="SwtBarcodeWithCaption_Toggled">
                </Switch>

            </Grid>
        </ScrollView>

        <Button
            Style="{StaticResource buttonStyleDefault}"
            Grid.Row="2"
            Text="{Translate SettingsSave_Text}"
            SemanticProperties.Description="{Translate ToolTipSettingsSave_Text}"
            ToolTipProperties.Text="{Translate ToolTipSettingsSave_Text}"
            Clicked="OnSettingsSaveClicked">
        </Button>

        <Button
            Style="{StaticResource buttonStyleDefault}"
            Grid.Row="2"
            HorizontalOptions="End"
            Text="{Translate SettingsReset_Text}"
            SemanticProperties.Description="{Translate ToolTipSettingsReset_Text}"
            ToolTipProperties.Text="{Translate ToolTipSettingsReset_Text}"
            Clicked="OnSettingsResetClicked">
        </Button>

    </Grid>
</ContentPage>
