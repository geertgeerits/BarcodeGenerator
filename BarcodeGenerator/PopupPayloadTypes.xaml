<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    x:Name="popupPayloadTypes"
    xmlns="http://schemas.microsoft.com/dotnet/maui/global"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:local="clr-namespace:BarcodeGenerator"
    x:DataType="local:LocalizationResourceManager"
    x:Class="BarcodeGenerator.PopupPayloadTypes"
    SafeAreaEdges="All"
    BackgroundColor="{AppThemeBinding Light={StaticResource LightGray}, Dark={StaticResource DarkGray}}"
    VerticalOptions="Start"
    MaximumHeightRequest="600"
    CanBeDismissedByTappingOutsideOfPopup="False">

    <!--Set the Text property of the Entry controls to "" for text values to eliminate null values if nothing has been entered.
    This is necessary to prevent null reference exceptions when the Text properties are accessed in the code-behind.-->

    <!--!!!BUG!!! in Android: The Editor and Entry controls do not have a 'Cut Copy Paste' context menu when using
    the 'ToolTipProperties' property.-->

    <ScrollView
        x:Name="scrollViewPayloadTypes"
        Style="{StaticResource scrollviewStylePopup}">

        <Grid
            x:Name="grdSettingsPayloadTypes"
            Style="{StaticResource gridStylePopup}"
            RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto"
            VerticalOptions="Start">

            <Label
                Style="{StaticResource labelStyleDefault}"
                Grid.Row="0"
                Grid.Column="0"
                SemanticProperties.Description="{Translate PayloadType_Text}"
                Text="{Translate PayloadType_Text}">
            </Label>

            <Border
                Style="{StaticResource borderStyleDefault}"
                Grid.Row="0"
                Grid.Column="1"
                Margin="0,6,6,0">

                <Picker
                    x:Name="pckPayloadType"
                    Style="{StaticResource pickerStyleSettings}"
                    SelectedIndexChanged="OnPickerPayloadTypeChanged">
                </Picker>
            </Border>

            <Label
                x:Name="lblWiFiAuthentication"
                Style="{StaticResource labelStyleDefault}"
                Grid.Row="1"
                Grid.Column="0"
                VerticalTextAlignment="Start"
                SemanticProperties.Description="{Translate PayloadTypeAuthentication_Text}"
                Text="{Translate PayloadTypeAuthentication_Text}">
            </Label>

            <Border
                x:Name="brdWiFiAuthentication"
                Style="{StaticResource borderStyleDefault}"
                Grid.Row="1"
                Grid.Column="1"
                Margin="0,6,6,0">

                <Picker
                    x:Name="pckWiFiAuthentication"
                    Style="{StaticResource pickerStyleSettings}"
                    SelectedIndexChanged="PckWiFiAuthentication_SelectedIndexChanged">
                    <Picker.ItemsSource>
                        <x:Array Type="{x:Type x:String}">
                            <x:String>WEP</x:String>
                            <x:String>WPA</x:String>
                            <x:String>WPA2</x:String>
                        </x:Array>
                    </Picker.ItemsSource>
                </Picker>
            </Border>

            <Border
                x:Name="brdPayloadTypeSSID"
                Style="{StaticResource borderStyleDefault}"
                Grid.Row="2"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Margin="0,6,6,0">

                <Entry
                    x:Name="entPayloadTypeSSID"
                    Placeholder="{Translate PayloadTypeSSID_Text}"
                    ClearButtonVisibility="WhileEditing"
                    Keyboard="Text"
                    ReturnType="Next"
                    Text="">
                </Entry>
            </Border>

            <Border
                x:Name="brdPayloadTypePassword"
                Style="{StaticResource borderStyleDefault}"
                Grid.Row="3"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Margin="0,6,6,0">

                <Entry
                    x:Name="entPayloadTypePassword"
                    Placeholder="{Translate PayloadTypePassword_Text}"
                    ClearButtonVisibility="WhileEditing"
                    Keyboard="Text"
                    ReturnType="Done"
                    Text="">
                </Entry>
            </Border>

            <Border
                x:Name="brdPayloadTypeURL"
                Style="{StaticResource borderStyleDefault}"
                Grid.Row="4"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Margin="0,6,6,0">

                <Entry
                    x:Name="entPayloadTypeURL"
                    Placeholder="{Translate PayloadTypeURL_Text}"
                    ClearButtonVisibility="WhileEditing"
                    Keyboard="Url"
                    ReturnType="Next"
                    Text=""
                    Focused="EntPayloadTypeURL_Focused">
                </Entry>
            </Border>

            <Border
                x:Name="brdPayloadTypeTitle"
                Style="{StaticResource borderStyleDefault}"
                Grid.Row="5"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Margin="0,6,6,0">

                <Entry
                    x:Name="entPayloadTypeTitle"
                    Placeholder="{Translate PayloadTypeTitle_Text}"
                    ClearButtonVisibility="WhileEditing"
                    Keyboard="Text"
                    ReturnType="Next"
                    Text="">
                </Entry>
            </Border>

            <Border
                x:Name="brdPayloadTypeReceiver"
                Style="{StaticResource borderStyleDefault}"
                Grid.Row="6"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Margin="0,6,6,0">

                <Entry
                    x:Name="entPayloadTypeReceiver"
                    Placeholder="{Translate PayloadTypeReceiver_Text}"
                    ClearButtonVisibility="WhileEditing"
                    Keyboard="Email"
                    ReturnType="Next"
                    Text=""
                    Focused="EntPayloadType_Focused">
                </Entry>
            </Border>

            <Border
                x:Name="brdPayloadTypeSubject"
                Style="{StaticResource borderStyleDefault}"
                Grid.Row="7"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Margin="0,6,6,0">

                <Entry
                    x:Name="entPayloadTypeSubject"
                    Placeholder="{Translate PayloadTypeSubject_Text}"
                    ClearButtonVisibility="WhileEditing"
                    Keyboard="Text"
                    ReturnType="Next"
                    Text=""
                    Focused="EntPayloadType_Focused">
                </Entry>
            </Border>

            <Label
                x:Name="lblGeolocationEncoding"
                Style="{StaticResource labelStyleDefault}"
                Grid.Row="8"
                Grid.Column="0"
                VerticalTextAlignment="Start"
                SemanticProperties.Description="{Translate GeolocationEncoding_Text}"
                Text="{Translate GeolocationEncoding_Text}">
            </Label>

            <Border
                x:Name="brdGeolocationEncoding"
                Style="{StaticResource borderStyleDefault}"
                Grid.Row="8"
                Grid.Column="1"
                Margin="0,6,6,0">
                
                <Picker
                    x:Name="pckGeolocationEncoding"
                    Style="{StaticResource pickerStyleSettings}"
                    SelectedIndexChanged="PckGeolocationEncoding_SelectedIndexChanged">
                    <Picker.ItemsSource>
                        <x:Array Type="{x:Type x:String}">
                            <x:String>Google</x:String>
                            <x:String>GEO</x:String>
                        </x:Array>
                    </Picker.ItemsSource>
                </Picker>
            </Border>

            <Label
                x:Name="lblPayloadTypeLatitude"
                Style="{StaticResource labelStyleDefault}"
                Grid.Row="9"
                Grid.Column="0"
                VerticalTextAlignment="Start"
                SemanticProperties.Description="{Translate PayloadTypeLatitude_Text}"
                Text="{Translate PayloadTypeLatitude_Text}">
            </Label>

            <Border
                x:Name="brdPayloadTypeLatitude"
                Style="{StaticResource borderStyleDefault}"
                Grid.Row="9"
                Grid.Column="1"
                Margin="0,6,6,0">

                <!--The iOS numeric keyboard does not have a negative sign.
                On other platforms, the keyboard is set to Numeric to provide a more suitable input method for numeric values.-->
                <Entry
                    x:Name="entPayloadTypeLatitude"
                    Placeholder="-90 - 90"
                    ClearButtonVisibility="WhileEditing"
                    Keyboard="{OnPlatform Default=Numeric, iOS=Default}"
                    ReturnType="Next"
                    Text=""
                    TextChanged="EntPayloadTypeLatitude_TextChanged"
                    Unfocused="EntPayloadTypeLatitude_Unfocused">
                </Entry>
            </Border>

            <Label
                x:Name="lblPayloadTypeLongitude"
                Style="{StaticResource labelStyleDefault}"
                Grid.Row="10"
                Grid.Column="0"
                VerticalTextAlignment="Start"
                SemanticProperties.Description="{Translate PayloadTypeLongitude_Text}"
                Text="{Translate PayloadTypeLongitude_Text}">
            </Label>

            <Border
                x:Name="brdPayloadTypeLongitude"
                Style="{StaticResource borderStyleDefault}"
                Grid.Row="10"
                Grid.Column="1"
                Margin="0,6,6,0">

                <Entry
                    x:Name="entPayloadTypeLongitude"
                    Placeholder="-180 - 180"
                    ClearButtonVisibility="WhileEditing"
                    Keyboard="{OnPlatform Default=Numeric, iOS=Default}"
                    ReturnType="Done"
                    Text=""
                    TextChanged="EntPayloadTypeLongitude_TextChanged"
                    Unfocused="EntPayloadTypeLongitude_Unfocused">
                </Entry>
            </Border>

            <Label
                x:Name="lblPayloadTypeLatitudeDMS"
                Style="{StaticResource labelStyleDefault}"
                Grid.Row="11"
                Grid.Column="0"
                VerticalTextAlignment="Start"
                SemanticProperties.Description="{Translate PayloadTypeLatitude_Text}"
                Text="{Translate PayloadTypeLatitude_Text}">
            </Label>

            <Border
                x:Name="brdPayloadTypeLatitudeDMSResult"
                Style="{StaticResource borderStyleDefault}"
                Grid.Row="11"
                Grid.Column="1"
                Margin="0,6,6,0">

                <Label
                    x:Name="lblPayloadTypeLatitudeDMSResult"
                    Style="{StaticResource labelStyleDefault}"
                    VerticalTextAlignment="Center"
                    Margin="10,0,0,0"
                    Padding="0">
                </Label>
            </Border>

            <Label
                x:Name="lblPayloadTypeLongitudeDMS"
                Style="{StaticResource labelStyleDefault}"
                Grid.Row="12"
                Grid.Column="0"
                VerticalTextAlignment="Start"
                SemanticProperties.Description="{Translate PayloadTypeLongitude_Text}"
                Text="{Translate PayloadTypeLongitude_Text}">
            </Label>

            <Border
                x:Name="brdPayloadTypeLongitudeDMSResult"
                Style="{StaticResource borderStyleDefault}"
                Grid.Row="12"
                Grid.Column="1"
                Margin="0,2,6,0">

                <Label
                    x:Name="lblPayloadTypeLongitudeDMSResult"
                    Style="{StaticResource labelStyleDefault}"
                    VerticalTextAlignment="Center"
                    Margin="10,0,0,0">
                </Label>
            </Border>

            <Border
                x:Name="brdPayloadTypeFirstname"
                Style="{StaticResource borderStyleDefault}"
                Grid.Row="13"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Margin="0,6,6,0">

                <Entry
                    x:Name="entPayloadTypeFirstname"
                    Placeholder="{Translate PayloadTypeFirstname_Text}"
                    ClearButtonVisibility="WhileEditing"
                    Keyboard="Text"
                    ReturnType="Next"
                    Text="">
                </Entry>
            </Border>

            <Border
                x:Name="brdPayloadTypeLastname"
                Style="{StaticResource borderStyleDefault}"
                Grid.Row="14"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Margin="0,6,6,0">

                <Entry
                    x:Name="entPayloadTypeLastname"
                    Placeholder="{Translate PayloadTypeLastname_Text}"
                    ClearButtonVisibility="WhileEditing"
                    Keyboard="Text"
                    ReturnType="Next"
                    Text="">
                </Entry>
            </Border>

            <Border
                x:Name="brdPayloadTypePhoneNumber"
                Style="{StaticResource borderStyleDefault}"
                Grid.Row="15"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Margin="0,6,6,0">

                <Entry
                    x:Name="entPayloadTypePhoneNumber"
                    Placeholder="{Translate PayloadTypePhoneNumber_Text}"
                    ClearButtonVisibility="WhileEditing"
                    Keyboard="Telephone"
                    ReturnType="Next"
                    Text=""
                    TextChanged="EntPayloadTypePhoneNumber_TextChanged"
                    Focused="EntPayloadType_Focused">
                </Entry>
            </Border>

            <Border
                x:Name="brdPayloadTypeMessage"
                Style="{StaticResource borderStyleDefault}"
                Grid.Row="16"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Margin="0,6,6,0">

                <ScrollView
                    VerticalScrollBarVisibility="Always">

                    <Editor
                        x:Name="edtPayloadTypeMessage"
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill"
                        AutoSize="TextChanges"
                        MinimumHeightRequest="100"
                        Placeholder="{Translate PayloadTypeMessage_Text}"
                        MaxLength="700"
                        Keyboard="Text"
                        Text=""
                        Focused="EdtPayloadTypeMessage_Focused">
                    </Editor>
                </ScrollView>
            </Border>

            <Border
                x:Name="brdPayloadTypeMail"
                Style="{StaticResource borderStyleDefault}"
                Grid.Row="17"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Margin="0,6,6,0">

                <Entry
                    x:Name="entPayloadTypeMail"
                    Placeholder="{Translate PayloadTypeMail_Text}"                    
                    ClearButtonVisibility="WhileEditing"
                    Keyboard="Email"
                    ReturnType="Next"
                    Text="">
                </Entry>
            </Border>

            <Border
                x:Name="brdPayloadTypeDescription"
                Style="{StaticResource borderStyleDefault}"
                Grid.Row="18"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Margin="0,6,6,0">

                <Entry
                    x:Name="entPayloadTypeDescription"
                    Placeholder="{Translate PayloadTypeDescription_Text}"
                    ClearButtonVisibility="WhileEditing"
                    Keyboard="Text"
                    ReturnType="Next"
                    Text="">
                </Entry>
            </Border>

            <Border
                x:Name="brdPayloadTypeLocation"
                Style="{StaticResource borderStyleDefault}"
                Grid.Row="19"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Margin="0,6,6,0">

                <Entry
                    x:Name="entPayloadTypeLocation"
                    Placeholder="{Translate PayloadTypeLocation_Text}"                    
                    ClearButtonVisibility="WhileEditing"
                    Keyboard="Text"
                    ReturnType="Done"
                    Text="">
                </Entry>
            </Border>

            <Label
                x:Name="lblPayloadTypeStart"
                Style="{StaticResource labelStyleDefault}"
                Grid.Row="20"
                Grid.Column="0"
                VerticalTextAlignment="Start"
                SemanticProperties.Description="{Translate PayloadTypeStart_Text}"
                Text="{Translate PayloadTypeStart_Text}">
            </Label>

            <!--!!!BUG!!! in Windows: The DatePicker and TimePicker do not take the width setting into account in Windows.-->

            <HorizontalStackLayout
                Grid.Row="20"
                Grid.Column="1">

                <Border
                    x:Name="brdPayloadTypeStartDate"
                    Style="{StaticResource borderStyleDefault}"
                    Margin="0,6,6,0">

                    <DatePicker
                        x:Name="dtpPayloadTypeStartDate"
                        BackgroundColor="{AppThemeBinding Light={StaticResource LightEntryBG}, Dark={StaticResource DarkEntryBG}}"
                        Format="d"
                        Unfocused="DtpPayloadTypeDate_Unfocused">
                    </DatePicker>
                </Border>

                <Border
                    x:Name="brdPayloadTypeStartTime"
                    Style="{StaticResource borderStyleDefault}"
                    Margin="10,6,6,0">

                    <TimePicker
                        x:Name="tmpPayloadTypeStartTime"
                        BackgroundColor="{AppThemeBinding Light={StaticResource LightEntryBG}, Dark={StaticResource DarkEntryBG}}"
                        Unfocused="DtpPayloadTypeTime_Unfocused">
                    </TimePicker>
                </Border>
            </HorizontalStackLayout>

            <Label
                x:Name="lblPayloadTypeEnd"
                Style="{StaticResource labelStyleDefault}"
                Grid.Row="21"
                Grid.Column="0"
                VerticalTextAlignment="Start"
                SemanticProperties.Description="{Translate PayloadTypeEnd_Text}"
                Text="{Translate PayloadTypeEnd_Text}">
            </Label>

            <HorizontalStackLayout
                Grid.Row="21"
                Grid.Column="1">

                <Border
                    x:Name="brdPayloadTypeEndDate"
                    Style="{StaticResource borderStyleDefault}"
                    Margin="0,6,6,0">

                    <DatePicker
                        x:Name="dtpPayloadTypeEndDate"
                        BackgroundColor="{AppThemeBinding Light={StaticResource LightEntryBG}, Dark={StaticResource DarkEntryBG}}"
                        Format="d"
                        Unfocused="DtpPayloadTypeDate_Unfocused">
                    </DatePicker>
                </Border>

                <Border
                    x:Name="brdPayloadTypeEndTime"
                    Style="{StaticResource borderStyleDefault}"
                    Margin="10,6,6,0">

                    <TimePicker
                        x:Name="tmpPayloadTypeEndTime"
                        BackgroundColor="{AppThemeBinding Light={StaticResource LightEntryBG}, Dark={StaticResource DarkEntryBG}}"
                        Unfocused="DtpPayloadTypeTime_Unfocused">
                    </TimePicker>
                </Border>
            </HorizontalStackLayout>

            <Border
                x:Name="brdPayloadTypeSctBic"
                Style="{StaticResource borderStyleDefault}"
                Grid.Row="24"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Margin="0,6,6,0">

                <Entry
                    x:Name="entPayloadTypeSctBic"
                    Placeholder="{Translate PayloadTypeSctBic_Text}"                    
                    ClearButtonVisibility="WhileEditing"
                    Keyboard="Text"
                    ReturnType="Next"
                    TextTransform="Uppercase"
                    MaxLength="11"
                    Text="">
                </Entry>
            </Border>

            <Border
                x:Name="brdPayloadTypeSctName"
                Style="{StaticResource borderStyleDefault}"
                Grid.Row="25"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Margin="0,6,6,0">

                <Entry
                    x:Name="entPayloadTypeSctName"
                    Placeholder="{Translate PayloadTypeSctName_Text}"                    
                    ClearButtonVisibility="WhileEditing"
                    Keyboard="Text"
                    ReturnType="Next"
                    MaxLength="70"
                    Text="">
                </Entry>
            </Border>

            <Border
                x:Name="brdPayloadTypeSctIban"
                Style="{StaticResource borderStyleDefault}"
                Grid.Row="26"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Margin="0,6,6,0">

                <Entry
                    x:Name="entPayloadTypeSctIban"
                    Placeholder="{Translate PayloadTypeSctIban_Text}"                    
                    ClearButtonVisibility="WhileEditing"
                    Keyboard="Text"
                    ReturnType="Next"
                    TextTransform="Uppercase"
                    MaxLength="34"
                    Text="">
                </Entry>
            </Border>

            <Border
                x:Name="brdPayloadTypeSctAmountEur"
                Style="{StaticResource borderStyleDefault}"
                Grid.Row="27"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Margin="0,6,6,0">

                <Entry
                    x:Name="entPayloadTypeSctAmountEur"
                    Placeholder="{Translate PayloadTypeSctAmountEur_Text}"                    
                    ClearButtonVisibility="WhileEditing"
                    Keyboard="Numeric"
                    ReturnType="Next"
                    MaxLength="12"
                    Text="">
                </Entry>
            </Border>

            <Border
                x:Name="brdPayloadTypeSctPurpose"
                Style="{StaticResource borderStyleDefault}"
                Grid.Row="28"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Margin="0,6,6,0">

                <Entry
                    x:Name="entPayloadTypeSctPurpose"
                    Placeholder="{Translate PayloadTypeSctPurpose_Text}"                    
                    ClearButtonVisibility="WhileEditing"
                    Keyboard="Text"
                    ReturnType="Next"
                    TextTransform="Uppercase"
                    MaxLength="4"
                    Text="">
                </Entry>
            </Border>

            <Border
                x:Name="brdPayloadTypeSctRemittanceInfoStructured"
                Style="{StaticResource borderStyleDefault}"
                Grid.Row="29"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Margin="0,6,6,0">

                <Entry
                    x:Name="entPayloadTypeSctRemittanceInfoStructured"
                    Placeholder="{Translate PayloadTypeSctRemittanceInfoStructured_Text}"                    
                    ClearButtonVisibility="WhileEditing"
                    Keyboard="Text"
                    ReturnType="Next"
                    TextTransform="Uppercase"
                    MaxLength="35"
                    Text=""
                    Focused="EntPayloadTypeSctRemittanceInfoStructured_Focused">
                </Entry>
            </Border>

            <Border
                x:Name="brdPayloadTypeSctRemittanceInfoUnstructured"
                Style="{StaticResource borderStyleDefault}"
                Grid.Row="30"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Margin="0,6,6,0">

                <Entry
                    x:Name="entPayloadTypeSctRemittanceInfoUnstructured"
                    Placeholder="{Translate PayloadTypeSctRemittanceInfoUnstructured_Text}"                    
                    ClearButtonVisibility="WhileEditing"
                    Keyboard="Text"
                    ReturnType="Next"
                    MaxLength="140"
                    Text="">
                </Entry>
            </Border>

            <Border
                x:Name="brdPayloadTypeSctInformation"
                Style="{StaticResource borderStyleDefault}"
                Grid.Row="31"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Margin="0,6,6,0">

                <Entry
                    x:Name="entPayloadTypeSctInformation"
                    Placeholder="{Translate PayloadTypeSctInformation_Text}"                    
                    ClearButtonVisibility="WhileEditing"
                    Keyboard="Text"
                    ReturnType="Done"
                    MaxLength="70"
                    Text="">
                </Entry>
            </Border>

            <ImageButton
                x:Name="btnButtonURL"
                Style="{StaticResource imageButtonStyleColorPicker}"
                Grid.Row="32"
                Grid.Column="1"
                HorizontalOptions="End"
                VerticalOptions="Start"
                WidthRequest="120"
                Margin="0,15,6,10"
                SemanticProperties.Description="{Translate ToolTipUrlLink_Text}"
                ToolTipProperties.Text="{Translate ToolTipUrlLink_Text}"
                Source="ic_action_link.png"
                Clicked="OnButtonURL_Clicked">
            </ImageButton>

            <ImageButton
                x:Name="btnButtonGeoLocation"
                Style="{StaticResource imageButtonStyleColorPicker}"
                Grid.Row="32"
                Grid.Column="0"
                HorizontalOptions="Start"
                VerticalOptions="Start"
                WidthRequest="120"
                Margin="0,15,0,10"
                SemanticProperties.Description="{Translate GeoLocationButton_Text}"
                ToolTipProperties.Text="{Translate GeoLocationButton_Text}"
                Source="ic_action_location.png"
                Clicked="OnButtonGeoLocation_Clicked">
            </ImageButton>

            <ImageButton
                x:Name="btnButtonGeoMap"
                Style="{StaticResource imageButtonStyleColorPicker}"
                Grid.Row="32"
                Grid.Column="1"
                HorizontalOptions="End"
                VerticalOptions="Start"
                WidthRequest="120"
                Margin="0,15,6,10"
                SemanticProperties.Description="{Translate GeoMapButton_Text}"
                ToolTipProperties.Text="{Translate GeoMapButton_Text}"
                Source="ic_action_map.png"
                Clicked="OnButtonGeoMap_Clicked">
            </ImageButton>

            <ImageButton
                x:Name="btnButtonCancel"
                Style="{StaticResource imageButtonStyleColorPicker}"
                Grid.Row="33"
                Grid.Column="0"
                HorizontalOptions="Start"
                VerticalOptions="Start"
                WidthRequest="120"
                Margin="0,15,0,10"
                SemanticProperties.Description="{Translate ButtonCancel_Text}"
                ToolTipProperties.Text="{Translate ButtonCancel_Text}"
                Source="ic_action_cancel_red.png"
                Clicked="OnButtonCancel_Clicked">
            </ImageButton>

            <ImageButton
                x:Name="imgbtnPasteFromClipboard"
                Grid.Row="33"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Source="paste_icon_48p_blue.png"
                HeightRequest="32"
                WidthRequest="32"
                SemanticProperties.Description="{Translate ToolTipPaste_Text}"
                ToolTipProperties.Text="{Translate ToolTipPaste_Text}"
                IsVisible="False"
                Clicked="OnPasteFromClipboard_Clicked">
            </ImageButton>

            <ImageButton
                x:Name="btnButtonClose"
                Style="{StaticResource imageButtonStyleColorPicker}"
                Grid.Row="33"
                Grid.Column="1"
                HorizontalOptions="End"
                VerticalOptions="Start"
                WidthRequest="120"
                Margin="0,15,6,0"
                SemanticProperties.Description="{Translate ButtonNext_Text}"
                ToolTipProperties.Text="{Translate ButtonNext_Text}"
                Source="ic_action_tick_green.png"
                Clicked="OnButtonClose_Clicked">
            </ImageButton>

        </Grid>
    </ScrollView>
</toolkit:Popup>
