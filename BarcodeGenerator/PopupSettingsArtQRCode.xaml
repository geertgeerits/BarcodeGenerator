<toolkit:Popup
    xmlns="http://schemas.microsoft.com/dotnet/maui/global"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:local="clr-namespace:BarcodeGenerator"
    x:Class="BarcodeGenerator.PopupSettingsArtQRCode"
    BackgroundColor="DimGray"
    CanBeDismissedByTappingOutsideOfPopup="False"
    Loaded="Popup_Loaded">
    
    <ScrollView
        WidthRequest="{OnIdiom 340, Phone=340, Tablet=560, Desktop=560}"
        Orientation="Vertical">

        <Grid
            RowDefinitions="Auto, Auto, Auto"
            ColumnDefinitions="120, 120*"
            VerticalOptions="Start">

            <BoxView
                Color="{AppThemeBinding Light={StaticResource LightGray}, Dark={StaticResource DarkGray}}"
                Grid.RowSpan="4"
                Grid.ColumnSpan="2"
                HorizontalOptions="Fill"
                VerticalOptions="Fill"
                CornerRadius="10"
                Margin="0">
            </BoxView>
            
            <Label
                x:Name="lblPopupTitle"
                Grid.Row="0"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                HorizontalOptions="Fill"
                VerticalOptions="Fill"
                BackgroundColor="Transparent"
                Margin="10,5,10,0"
                TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                HorizontalTextAlignment="Center"
                Text="{Translate ColorPicker_Text}">
            </Label>

            <local:ClassArtQRCodeSettings
                Grid.Row="1"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                HeightRequest="560"
                VerticalOptions="Start">
            </local:ClassArtQRCodeSettings>

            <ImageButton
                x:Name="btnButtonCancel"
                Style="{StaticResource imageButtonStyleColorPicker}"
                Grid.Row="2"
                Grid.Column="0"
                HorizontalOptions="Start"
                VerticalOptions="End"
                WidthRequest="120"
                Margin="4,5,0,5"
                ToolTipProperties.Text="{Translate ButtonCancel_Text}"
                Source="ic_action_cancel_red.png"
                Clicked="OnButtonCancel_Clicked">
            </ImageButton>

            <ImageButton
                x:Name="btnButtonClose"
                Style="{StaticResource imageButtonStyleColorPicker}"
                Grid.Row="2"
                Grid.Column="1"
                HorizontalOptions="End"
                VerticalOptions="End"
                WidthRequest="120"
                Margin="0,5,4,5"
                ToolTipProperties.Text="{Translate ButtonNext_Text}"
                Source="ic_action_tick_green.png"
                Clicked="OnButtonClose_Clicked">
            </ImageButton>

        </Grid>
    </ScrollView>
</toolkit:Popup>
