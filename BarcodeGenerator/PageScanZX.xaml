<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/maui/global"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
             xmlns:barcodegenerator="clr-namespace:BarcodeGenerator"
             x:DataType="barcodegenerator:LocalizationResourceManager"
             x:Class="BarcodeGenerator.PageScanZX"
             SafeAreaEdges="All"
             Appearing="OnPageAppearing"
             Disappearing="OnPageDisappearing">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Style x:Key="zxingCameraView" TargetType="zxing:CameraBarcodeReaderView">
                    <Setter Property="VisualStateManager.VisualStateGroups">
                        <VisualStateGroupList>
                            <VisualStateGroup>
                                <VisualState x:Name="Portrait">
                                    <VisualState.StateTriggers>
                                        <OrientationStateTrigger Orientation="Portrait" />
                                    </VisualState.StateTriggers>
                                    <VisualState.Setters>
                                        <Setter Property="HeightRequest" Value="{OnIdiom 400, Phone=400, Tablet=600, Desktop=600}" />
                                        <Setter Property="WidthRequest" Value="{OnIdiom 310, Phone=310, Tablet=600, Desktop=600}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Landscape">
                                    <VisualState.StateTriggers>
                                        <OrientationStateTrigger Orientation="Landscape" />
                                    </VisualState.StateTriggers>
                                    <VisualState.Setters>
                                        <Setter Property="HeightRequest" Value="{OnIdiom 310, Phone=310, Tablet=450, Desktop=450}" />
                                        <Setter Property="WidthRequest" Value="{OnIdiom 510, Phone=510, Tablet=800, Desktop=800}" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateGroupList>
                    </Setter>
                </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Shell.TitleView>
        <Grid
            RowDefinitions="Auto"
            ColumnDefinitions="100*, 60, 60, 60, Auto, Auto">

            <Label
                x:Name="lblTitle"
                Style="{StaticResource labelStyleTitleView}"
                Grid.Row="0"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Text="{Translate BarcodeScanner_Text}">
            </Label>

            <ActivityIndicator
                x:Name="activityIndicator"
                Grid.Column="1"
                HeightRequest="46"
                WidthRequest="46"
                Margin="2"
                VerticalOptions="Center"
                HorizontalOptions="End"
                Color="Gold"
                IsRunning="False">
            </ActivityIndicator>

            <ImageButton
                x:Name="imgbtnCameraDetecting"
                Grid.Column="2"
                HeightRequest="40"
                WidthRequest="40"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Source="camera_detect_off_128x128p.png"
                SemanticProperties.Description="{Translate ToolTipCameraDetecting_Text}"
                ToolTipProperties.Text="{Translate ToolTipCameraDetecting_Text}"
                Clicked="OnCameraDetecting_Clicked">
            </ImageButton>
            
            <ImageButton
                x:Name="imgbtnTorch"
                Grid.Row="0"
                Grid.Column="3"
                Source="camera_torch_on_64x64p.png"
                HeightRequest="36"
                WidthRequest="36"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                SemanticProperties.Description="{Translate ToolTipCameraTorch_Text}"
                ToolTipProperties.Text="{Translate ToolTipCameraTorch_Text}"
                Clicked="OnTorchClicked">
            </ImageButton>

            <ImageButton
                x:Name="imgbtnScanFromCamera"
                Grid.Column="4"
                Source="ic_action_camera.png"
                HeightRequest="44"
                WidthRequest="44"
                SemanticProperties.Description="{Translate ToolTipScanCamera_Text}"
                ToolTipProperties.Text="{Translate ToolTipScanCamera_Text}"
                IsVisible="False"
                Clicked="OnScanFromCamera_Clicked">
            </ImageButton>

            <ImageButton
                x:Name="imgbtnScanFromImage"
                Grid.Column="5"
                Source="ic_action_picture.png"
                HeightRequest="50"
                WidthRequest="50"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                SemanticProperties.Description="{Translate ToolTipScanImage_Text}"
                ToolTipProperties.Text="{Translate ToolTipScanImage_Text}"
                IsVisible="False"
                Clicked="OnScanFromImage_Clicked">
            </ImageButton>
        </Grid>
    </Shell.TitleView>

    <ScrollView>
        <StackLayout>
            <Grid
                Style="{StaticResource gridStyleScanner}"
                RowDefinitions="Auto, 5, Auto, 5, Auto, Auto">

                <Label
                    Style="{StaticResource labelStyleDefault}"
                    Grid.Row="0"
                    Grid.Column="0"
                    Text="{Translate FormatCode_Text}">
                </Label>
                
                <Border
                    Style="{StaticResource borderStyleDefault}"
                    Grid.Row="0"
                    Grid.Column="1"
                    VerticalOptions="Center">

                    <Picker
                        x:Name="pckFormatCodeScanner"
                        MinimumWidthRequest="{OnIdiom 200, Phone=200, Tablet=300, Desktop=300}"
                        SelectedIndexChanged="OnPickerFormatCodeChanged">
                    </Picker>
                </Border>

                <Border
                    Grid.Row="2"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    HorizontalOptions="Fill"
                    VerticalOptions="Fill"
                    BackgroundColor="Transparent"
                    Stroke="Transparent">

                    <zxing:CameraBarcodeReaderView
                        x:Name="barcodeReader"
                        Style="{StaticResource zxingCameraView}"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        IsTorchOn="False"
                        BarcodesDetected="OnBarcodesDetected">
                    </zxing:CameraBarcodeReaderView>
                </Border>

                <Image
                    x:Name="imgScanFromImage"
                    Grid.Row="2"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    IsVisible="False">
                </Image>

                <HorizontalStackLayout
                    Grid.Row="4"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    HorizontalOptions="Start"
                    VerticalOptions="Center">

                    <ImageButton
                        x:Name="imgbtnCopyToClipboard"
                        Source="copy_icon_48p_blue.png"
                        HeightRequest="38"
                        WidthRequest="38"
                        VerticalOptions="End"
                        SemanticProperties.Description="{Translate ToolTipCopy_Text}"
                        ToolTipProperties.Text="{Translate ToolTipCopy_Text}"
                        IsEnabled="False"
                        Clicked="OnCopyToClipboardClicked">
                    </ImageButton>

                    <Button
                        x:Name="btnShare"
                        HorizontalOptions="Start"
                        VerticalOptions="End"
                        MinimumWidthRequest="{OnIdiom 160, Phone=160, Tablet=210, Desktop=210}"
                        MaximumWidthRequest="{OnIdiom 200, Phone=200, Tablet=250, Desktop=250}"
                        Text="{Translate ButtonShare_Text}"
                        ToolTipProperties.Text="{Translate ButtonShare_Text}"
                        IsEnabled="False"
                        Clicked="OnShareClicked">
                    </Button>
                </HorizontalStackLayout>

                <HorizontalStackLayout
                    Grid.Row="4"
                    Grid.Column="1"
                    HorizontalOptions="End"
                    VerticalOptions="Center"
                    Spacing="10">
                    
                    <Label
                        x:Name="lblTextToSpeech"
                        Style="{StaticResource labelStyleDefault}"
                        HorizontalOptions="End"
                        HorizontalTextAlignment="End"
                        Margin="{OnPlatform Default='0', WinUI='0,15,0,0'}"
                        IsVisible="False"
                        Text="en-US">
                    </Label>

                    <ImageButton
                        x:Name="imgbtnTextToSpeech"
                        Source="speaker_64p_blue_green.png"
                        HorizontalOptions="End"
                        HeightRequest="38"
                        WidthRequest="38"
                        IsVisible="False"
                        SemanticProperties.Description="{Translate ToolTipTextToSpeech_Text}"
                        ToolTipProperties.Text="{Translate ToolTipTextToSpeech_Text}"                        
                        Clicked="OnTextToSpeechClicked">
                    </ImageButton>
                </HorizontalStackLayout>

                <Border
                    Style="{StaticResource borderStyleDefault}"
                    Grid.Row="5"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    HorizontalOptions="Fill"
                    VerticalOptions="Fill"
                    BackgroundColor="{AppThemeBinding Light={StaticResource LightGray}, Dark={StaticResource DarkGray}}">

                    <Label
                        x:Name="lblBarcodeResult"
                        Padding="5"
                        HorizontalOptions="Start"
                        HorizontalTextAlignment="Start"
                        VerticalTextAlignment="Start"
                        Text="">
                    </Label>
                </Border>
            </Grid>
        
        </StackLayout>
    </ScrollView>
</ContentPage>
    